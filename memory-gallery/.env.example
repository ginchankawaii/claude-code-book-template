# Notion 統合トークン（★接続を付与したページしか見えない — 404の主因）
NOTION_TOKEN=

# Anthropic API キー（L1 連想層・事実照合ゲート）
ANTHROPIC_API_KEY=

# 使用モデル（省略時 claude-sonnet-5）
MEMORY_GALLERY_MODEL=claude-sonnet-5

# 作画用 (Nano Banana / Gemini)。https://aistudio.google.com/apikey で発行
GEMINI_API_KEY=

# 画像生成モデル（省略時 gemini-3-pro-image-preview。404になる場合はエラー表示の候補から選んで指定）
# GEMINI_IMAGE_MODEL=
