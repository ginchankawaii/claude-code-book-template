# ---- Claude API（AI売買判断に必要）----
# https://console.anthropic.com で取得したキーを設定
ANTHROPIC_API_KEY=
# 判断に使うモデル（任意）
ADVISOR_MODEL=claude-sonnet-4-6

# ---- 株価データソース ----
# yahoo | stooq | mock
#   yahoo / stooq : 実際の株価を取得（要ネットワーク・APIキー不要）
#   mock          : オフライン用の擬似データ（ネットワーク不要）
MARKET_DATA_SOURCE=yahoo
# 実データ取得に失敗したら mock に自動フォールバックするか
MARKET_FALLBACK_TO_MOCK=true

# ---- シミュレーション設定 ----
# 初期の仮想資金（円）
STARTING_CASH=1000000
# 単元株数
TRADE_UNIT=100
# 初期ウォッチリスト（証券コードをカンマ区切り）
DEFAULT_WATCHLIST=7203,6758,9984,7974,9432,8306
