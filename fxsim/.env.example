# Copy to .env and `set -a; . ./.env; set +a` before running, or export manually.

# --- data provider -------------------------------------------------------
# "sample" = fully offline synthetic data (no network, default)
# "csv"    = REAL data exported from any broker, e.g. data/USD_JPY.csv (no network)
# "oanda"  = real prices from OANDA v20 (requires token + allow-listed host)
FXSIM_PROVIDER=sample

# OANDA v20 — free practice (demo) account. We only READ prices; fills simulated.
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice          # practice | live

# --- market --------------------------------------------------------------
FXSIM_INSTRUMENTS=USD_JPY
FXSIM_GRANULARITY=H1        # H1 = OOS-validated aggressive default (research_run8)

# --- account / risk ------------------------------------------------------
FXSIM_BALANCE=500000        # account currency = the pair's QUOTE currency (JPY for USD_JPY)
FXSIM_RISK=0.04             # fraction of equity risked per trade (aggressive: 0.04, conservative: 0.02)
FXSIM_MAX_UNITS=100000
FXSIM_MAX_LEVERAGE=5        # hard ceiling: notional <= 5x equity (0 disables). Both aggression dial AND safety brake
FXSIM_SPREAD_PIPS=0.8
FXSIM_COMMISSION=50         # per 1,000,000 units

# --- strategy ------------------------------------------------------------
FXSIM_W_TECH=0.6
FXSIM_W_FUND=0.4
FXSIM_ENTRY_TH=0.20
FXSIM_EXIT_TH=0.08

# --- fundamental analysis ------------------------------------------------
# "stub"=neutral (default; keeps the bare trend edge), "file"=data/fundamental.json,
# "anthropic"=live Claude+web-search macro/news bias (the real "Opus fundamental")
FXSIM_FUND_MODE=stub
ANTHROPIC_API_KEY=
FXSIM_FUND_MODEL=claude-opus-4-8

# --- strategy selection --------------------------------------------------
# "ai"    = trend edge + Opus/event overlay (DEFAULT; see below)
# "trend" = bare long-biased trend filter (the raw OOS-validated edge)
# "combined"/"off" = plain mechanical technical+fundamental blend
FXSIM_STRATEGY=ai
FXSIM_AI_BASE=trend          # AI technical base: "trend" (the edge) | "technical" (legacy ensemble)
FXSIM_TREND_SMA=2400         # ~100-day trend filter on H1 bars (1800-2400 robust). Use 90 on daily.
FXSIM_USE_TAKE_PROFIT=0      # 0 = let winners run (trend); 1 = fixed 2:1 take-profit

# --- AI decision layer ---------------------------------------------------
# Who makes the final call (weighing technicals + fundamentals + the event
# calendar together, instead of a fixed formula):
#   "rule"      = deterministic, offline, no key (default)
#   "hybrid"    = free rule by default; consult Claude only at turning points
#                 (entry/reversal, borderline, disagreement, near a big event),
#                 where Claude acts as a veto/shrink gate. Caches its verdict
#                 while the view holds steady to minimise API calls.
#   "anthropic" = Claude decides on every bar (needs key; costly on fine data)
#   "off"       = legacy mechanical technical+fundamental blend
# Default "hybrid": Opus checks fundamentals/events at the key moments, offline-safe.
FXSIM_DECISION_MODE=hybrid
FXSIM_DECISION_MODEL=claude-opus-4-8
# Economic calendar (scheduled events known in advance):
#   "file"=data/calendar.json, "stub"=none, "anthropic"=Claude+web-search compiles it
FXSIM_CALENDAR_MODE=file
# Stand aside this many minutes either side of a high-impact event (risk control)
FXSIM_EVENT_BLACKOUT_MIN=60
# Trim conviction when a high-impact event is within this many minutes ahead
FXSIM_EVENT_CAUTION_MIN=360

# --- storage -------------------------------------------------------------
FXSIM_DB=data/fxsim.db
